generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(uuid())
  phoneNumber  String        @unique
  name         String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  transactions Transaction[]
  RawSms       RawSms[]
}

model RawSms {
  id           String   @id @default(uuid())
  userId       String
  body         String
  sender       String
  hash         String   @unique // Hash of body+userId+sender for deduplication
  processed    Boolean  @default(false)
  confidence   Float?   // Storing parser confidence
  receivedAt   DateTime
  createdAt    DateTime @default(now())
  
  user         User          @relation(fields: [userId], references: [id])
  transaction  Transaction?
}

model Transaction {
  id               String   @id @default(uuid())
  userId           String
  rawSmsId         String?  @unique
  amount           Float
  type             TxType   // EXPENSE | INCOME | UNKNOWN
  currency         String   @default("INR") // Configured as INR initially
  merchant         String?
  category         Category @default(OTHER)
  confidence       Float
  isAiParsed       Boolean  @default(false)
  transactionDate  DateTime
  manualCorrection Boolean  @default(false)
  status           TxStatus @default(COMPLETED) // COMPLETED | FAILED | REFUND
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  user             User     @relation(fields: [userId], references: [id])
  rawSms           RawSms?  @relation(fields: [rawSmsId], references: [id])
}

enum TxType {
  EXPENSE
  INCOME
  UNKNOWN
}

enum TxStatus {
  COMPLETED
  FAILED
  REFUND
}

enum Category {
  FOOD
  TRAVEL
  SHOPPING
  BILLS
  ENTERTAINMENT
  OTHER
}
